#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

command -v swift >/dev/null || {
  echo "error: Swift is required. Install the current Xcode command-line tools." >&2
  exit 1
}

swift package resolve
echo "BonsAI dependencies are ready."
